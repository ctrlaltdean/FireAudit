<?xml version="1.0" encoding="UTF-8"?>
<Configuration firmware_version="SFOS 18.5.3 MR-3">

  <Global>
    <SystemInformation>
      <SystemName>SOPHOS-XG-01</SystemName>
      <Model>XG 135</Model>
      <SerialNumber>SFG001234567890</SerialNumber>
    </SystemInformation>

    <AdminSettings>
      <HTTPSPort>4444</HTTPSPort>
      <SSHPort>22</SSHPort>
      <IdleSessionTimeout>10</IdleSessionTimeout>
      <LoginBanner>UNAUTHORIZED ACCESS PROHIBITED. All activity is monitored.</LoginBanner>
      <MaximumLoginAttempts>5</MaximumLoginAttempts>
      <LockoutDuration>300</LockoutDuration>
      <PasswordMinLength>12</PasswordMinLength>
      <PasswordComplexity>Enable</PasswordComplexity>
      <PasswordMaxAge>90</PasswordMaxAge>
      <PasswordHistory>5</PasswordHistory>
    </AdminSettings>

    <ManagementProtocols>
      <HTTPS>Enable</HTTPS>
      <HTTP>Disable</HTTP>
      <SSH>Enable</SSH>
      <Telnet>Disable</Telnet>
    </ManagementProtocols>

    <TLSSettings>
      <MinTLSVersion>TLSv1.2</MinTLSVersion>
    </TLSSettings>

    <TrustedHosts>
      <Host>10.10.1.0/24</Host>
      <Host>10.10.2.50/32</Host>
    </TrustedHosts>

    <SNMPSettings>
      <Enabled>Enable</Enabled>
      <Version>v3</Version>
      <CommunityName>sophos-community</CommunityName>
    </SNMPSettings>
  </Global>

  <NTP>
    <Enabled>Enable</Enabled>
    <Server>pool.ntp.org</Server>
    <Server>time.cloudflare.com</Server>
  </NTP>

  <Syslog>
    <SyslogServer>
      <Name>SIEM-Primary</Name>
      <Enabled>Enable</Enabled>
      <IPAddress>10.10.1.200</IPAddress>
      <Port>514</Port>
      <Protocol>UDP</Protocol>
      <Facility>DAEMON</Facility>
      <Severity>Information</Severity>
    </SyslogServer>
    <SyslogServer>
      <Name>SIEM-Secondary</Name>
      <Enabled>Enable</Enabled>
      <IPAddress>10.10.1.201</IPAddress>
      <Port>6514</Port>
      <Protocol>TCP</Protocol>
    </SyslogServer>
  </Syslog>

  <Network>
    <Interface>
      <Name>Port1</Name>
      <Zone>LAN</Zone>
      <IPAddress>10.10.1.1</IPAddress>
      <Netmask>255.255.255.0</Netmask>
      <Status>Enable</Status>
      <Description>LAN Interface</Description>
    </Interface>
    <Interface>
      <Name>Port2</Name>
      <Zone>WAN</Zone>
      <IPAddress>203.0.113.5</IPAddress>
      <Netmask>255.255.255.248</Netmask>
      <Status>Enable</Status>
      <Description>WAN Interface</Description>
    </Interface>
  </Network>

  <Firewall>
    <FirewallRule>
      <Name>LAN-to-WAN</Name>
      <Status>Enable</Status>
      <Action>Accept</Action>
      <SourceZones>
        <Zone>LAN</Zone>
      </SourceZones>
      <DestZones>
        <Zone>WAN</Zone>
      </DestZones>
      <SourceNetworks>
        <Network>CORP-NET</Network>
      </SourceNetworks>
      <DestNetworks>
        <Network>Any</Network>
      </DestNetworks>
      <Services>
        <Service>Any</Service>
      </Services>
      <LogTraffic>Enable</LogTraffic>
    </FirewallRule>
    <FirewallRule>
      <Name>Allow-HTTPS-DMZ</Name>
      <Status>Enable</Status>
      <Action>Accept</Action>
      <SourceZones>
        <Zone>WAN</Zone>
      </SourceZones>
      <DestZones>
        <Zone>DMZ</Zone>
      </DestZones>
      <SourceNetworks>
        <Network>Any</Network>
      </SourceNetworks>
      <DestNetworks>
        <Network>DMZ-SERVER</Network>
      </DestNetworks>
      <Services>
        <Service>HTTPS</Service>
      </Services>
      <LogTraffic>Enable</LogTraffic>
    </FirewallRule>
    <FirewallRule>
      <Name>Deny-All-Inbound</Name>
      <Status>Enable</Status>
      <Action>Drop</Action>
      <SourceZones>
        <Zone>WAN</Zone>
      </SourceZones>
      <DestZones>
        <Zone>LAN</Zone>
      </DestZones>
      <SourceNetworks>
        <Network>Any</Network>
      </SourceNetworks>
      <DestNetworks>
        <Network>Any</Network>
      </DestNetworks>
      <Services>
        <Service>Any</Service>
      </Services>
      <LogTraffic>Enable</LogTraffic>
    </FirewallRule>
    <FirewallRule>
      <Name>TEMP-Any-Any</Name>
      <Status>Enable</Status>
      <Action>Accept</Action>
      <SourceZones>
        <Zone>LAN</Zone>
      </SourceZones>
      <DestZones>
        <Zone>WAN</Zone>
      </DestZones>
      <SourceNetworks>
        <Network>Any</Network>
      </SourceNetworks>
      <DestNetworks>
        <Network>Any</Network>
      </DestNetworks>
      <Services>
        <Service>Any</Service>
      </Services>
      <LogTraffic>Disable</LogTraffic>
    </FirewallRule>
  </Firewall>

  <Hosts>
    <Host>
      <Name>CORP-NET</Name>
      <HostType>Network</HostType>
      <IPAddress>10.10.1.0</IPAddress>
      <Subnet>255.255.255.0</Subnet>
    </Host>
    <Host>
      <Name>DMZ-SERVER</Name>
      <HostType>IP</HostType>
      <IPAddress>10.20.1.100</IPAddress>
    </Host>
  </Hosts>

  <Services>
    <Service>
      <Name>HTTPS</Name>
      <Type>TCPorUDP</Type>
      <Protocol>TCP</Protocol>
      <DestinationPort>443</DestinationPort>
    </Service>
    <Service>
      <Name>CUSTOM-APP</Name>
      <Type>TCPorUDP</Type>
      <Protocol>TCP</Protocol>
      <DestinationPort>8443</DestinationPort>
    </Service>
  </Services>

  <Authentication>
    <LocalUser>
      <Username>admin</Username>
      <UserType>Administrator</UserType>
      <Status>Enable</Status>
      <MFA>Disable</MFA>
    </LocalUser>
    <LocalUser>
      <Username>svc-monitor</Username>
      <UserType>User</UserType>
      <Status>Enable</Status>
      <MFA>Enable</MFA>
    </LocalUser>
    <PasswordPolicy>
      <MinLength>12</MinLength>
      <Complexity>Enable</Complexity>
      <MaxAge>90</MaxAge>
      <History>5</History>
      <LockoutThreshold>5</LockoutThreshold>
    </PasswordPolicy>
    <RADIUSServer>
      <Enabled>Enable</Enabled>
      <ServerAddress>10.10.1.150</ServerAddress>
      <AuthPort>1812</AuthPort>
    </RADIUSServer>
  </Authentication>

  <VPN>
    <IPSecConnection>
      <Name>HQ-IPSEC</Name>
      <Status>Enable</Status>
      <RemoteHost>198.51.100.10</RemoteHost>
      <AuthMode>PSK</AuthMode>
      <IKEVersion>2</IKEVersion>
      <Phase1Settings>
        <Encryption>AES256</Encryption>
        <Authentication>SHA2_256</Authentication>
        <DHGroup>14</DHGroup>
        <Lifetime>28800</Lifetime>
      </Phase1Settings>
      <Phase2Settings>
        <Encryption>AES256</Encryption>
        <Authentication>SHA2_256</Authentication>
        <PFS>Enable</PFS>
        <DHGroup>14</DHGroup>
        <Lifetime>3600</Lifetime>
      </Phase2Settings>
    </IPSecConnection>
    <IPSecConnection>
      <Name>LEGACY-IPSEC</Name>
      <Status>Enable</Status>
      <RemoteHost>192.0.2.50</RemoteHost>
      <AuthMode>PSK</AuthMode>
      <IKEVersion>1</IKEVersion>
      <Phase1Settings>
        <Encryption>3DES</Encryption>
        <Authentication>MD5</Authentication>
        <DHGroup>2</DHGroup>
        <Lifetime>28800</Lifetime>
      </Phase1Settings>
      <Phase2Settings>
        <Encryption>3DES</Encryption>
        <Authentication>MD5</Authentication>
        <PFS>Disable</PFS>
        <DHGroup>2</DHGroup>
        <Lifetime>28800</Lifetime>
      </Phase2Settings>
    </IPSecConnection>
    <SSLVPNServerSettings>
      <Enabled>Enable</Enabled>
      <TLSMinVersion>TLSv1.2</TLSMinVersion>
      <ClientCertRequired>Disable</ClientCertRequired>
      <SplitTunneling>Disable</SplitTunneling>
    </SSLVPNServerSettings>
  </VPN>

</Configuration>
