<?xml version="1.0"?>
<pfsense>
  <version>21.7.3</version>
  <lastchange></lastchange>
  <system>
    <hostname>pfsense-branch</hostname>
    <domain>corp.example.com</domain>
    <dnsserver>10.10.1.10</dnsserver>
    <dnsserver>8.8.8.8</dnsserver>
    <timeservers>pool.ntp.org time.cloudflare.com</timeservers>
    <timezone>America/New_York</timezone>
    <language>en_US</language>
    <loginprotection/>
    <webgui>
      <protocol>https</protocol>
      <ssl-certref>cert_ref_1</ssl-certref>
      <port>443</port>
      <session-timeout>10</session-timeout>
      <loginautocomplete>enabled</loginautocomplete>
    </webgui>
    <ssh>
      <enable>enabled</enable>
      <sshdkeyonly>enabled</sshdkeyonly>
      <port>22</port>
    </ssh>
    <user>
      <name>admin</name>
      <descr>System Administrator</descr>
      <scope>system</scope>
      <groupname>admins</groupname>
      <bcrypt-hash>$2y$10$somebcrypthash</bcrypt-hash>
      <uid>0</uid>
    </user>
    <user>
      <name>svc-monitor</name>
      <descr>Monitoring Account</descr>
      <scope>local</scope>
      <groupname>readonly</groupname>
      <bcrypt-hash>$2y$10$anotherhash</bcrypt-hash>
      <uid>1001</uid>
      <otp_seed>JBSWY3DPEHPK3PXP</otp_seed>
    </user>
    <authserver>
      <name>CORP-RADIUS</name>
      <type>radius</type>
      <host>10.10.1.150</host>
      <radius_auth_port>1812</radius_auth_port>
      <radius_acct_port>1813</radius_acct_port>
      <radius_protocol>MSCHAPv2</radius_protocol>
    </authserver>
  </system>

  <interfaces>
    <wan>
      <if>em0</if>
      <descr>WAN</descr>
      <ipaddr>203.0.113.5</ipaddr>
      <subnet>29</subnet>
      <gateway>ISP_GW</gateway>
    </wan>
    <lan>
      <if>em1</if>
      <descr>LAN</descr>
      <ipaddr>10.10.1.1</ipaddr>
      <subnet>24</subnet>
    </lan>
    <opt1>
      <if>em2</if>
      <descr>DMZ</descr>
      <ipaddr>10.20.1.1</ipaddr>
      <subnet>24</subnet>
    </opt1>
  </interfaces>

  <syslog>
    <enable>on</enable>
    <remoteserver>10.10.1.200</remoteserver>
    <remoteport>514</remoteport>
    <remoteserver2>10.10.1.201:6514</remoteserver2>
    <filter>on</filter>
    <dhcp>on</dhcp>
    <auth>on</auth>
    <system>on</system>
    <vpn>on</vpn>
    <portalauth>on</portalauth>
  </syslog>

  <snmpd>
    <enable>on</enable>
    <syslocation>Branch Office</syslocation>
    <syscontact>noc@example.com</syscontact>
    <rocommunity>public</rocommunity>
    <bindip>10.10.1.1</bindip>
  </snmpd>

  <filter>
    <rule>
      <id>1</id>
      <type>pass</type>
      <interface>lan</interface>
      <ipprotocol>inet</ipprotocol>
      <protocol>tcp/udp</protocol>
      <source>
        <network>lan</network>
      </source>
      <destination>
        <any/>
      </destination>
      <descr>LAN to Any - Main Outbound Rule</descr>
      <log/>
    </rule>
    <rule>
      <id>2</id>
      <type>pass</type>
      <interface>wan</interface>
      <ipprotocol>inet</ipprotocol>
      <protocol>tcp</protocol>
      <source>
        <any/>
      </source>
      <destination>
        <address>10.20.1.100</address>
        <mask>32</mask>
        <port>443</port>
      </destination>
      <descr>Allow HTTPS to DMZ Server</descr>
      <log/>
    </rule>
    <rule>
      <id>3</id>
      <type>block</type>
      <interface>wan</interface>
      <ipprotocol>inet</ipprotocol>
      <protocol>any</protocol>
      <source>
        <any/>
      </source>
      <destination>
        <any/>
      </destination>
      <descr>Block All Inbound</descr>
      <log/>
    </rule>
    <rule>
      <id>4</id>
      <type>pass</type>
      <interface>lan</interface>
      <ipprotocol>inet</ipprotocol>
      <protocol>any</protocol>
      <source>
        <any/>
      </source>
      <destination>
        <any/>
      </destination>
      <descr>TEMP Any-Any - Remove after testing</descr>
    </rule>
  </filter>

  <ipsec>
    <phase1>
      <ikeid>1</ikeid>
      <descr>HQ-Tunnel</descr>
      <interface>wan</interface>
      <remote-gateway>198.51.100.10</remote-gateway>
      <authentication_method>pre_shared_key</authentication_method>
      <myid_type>myaddress</myid_type>
      <peerid_type>peeraddress</peerid_type>
      <pre-shared-key>$ekt=somethinghashed</pre-shared-key>
      <encryption-algorithm-option>
        <name>aes</name>
        <keylen>256</keylen>
      </encryption-algorithm-option>
      <hash-algorithm-option>sha256</hash-algorithm-option>
      <dhgroup>14</dhgroup>
      <lifetime>28800</lifetime>
      <iketype>ikev2</iketype>
    </phase1>
    <phase1>
      <ikeid>2</ikeid>
      <descr>Partner-Legacy-Tunnel</descr>
      <interface>wan</interface>
      <remote-gateway>192.0.2.50</remote-gateway>
      <authentication_method>pre_shared_key</authentication_method>
      <pre-shared-key>$ekt=legacyhashed</pre-shared-key>
      <encryption-algorithm-option>
        <name>3des</name>
      </encryption-algorithm-option>
      <hash-algorithm-option>md5</hash-algorithm-option>
      <dhgroup>2</dhgroup>
      <lifetime>28800</lifetime>
      <iketype>ikev1</iketype>
      <disabled/>
    </phase1>
    <phase2>
      <uniqid>abc123</uniqid>
      <ikeid>1</ikeid>
      <mode>tunnel</mode>
      <encryption-algorithm-option>
        <name>aes</name>
        <keylen>256</keylen>
      </encryption-algorithm-option>
      <hash-algorithm-option>sha256</hash-algorithm-option>
      <pfsgroup>14</pfsgroup>
      <lifetime>3600</lifetime>
    </phase2>
    <phase2>
      <uniqid>def456</uniqid>
      <ikeid>2</ikeid>
      <mode>tunnel</mode>
      <encryption-algorithm-option>
        <name>3des</name>
      </encryption-algorithm-option>
      <hash-algorithm-option>md5</hash-algorithm-option>
      <pfsgroup>2</pfsgroup>
      <lifetime>28800</lifetime>
    </phase2>
  </ipsec>

  <openvpn>
    <openvpn-server>
      <vpnid>1</vpnid>
      <mode>server_tls</mode>
      <protocol>UDP4</protocol>
      <dev_mode>tun</dev_mode>
      <interface>wan</interface>
      <local_port>1194</local_port>
      <description>Remote Access VPN</description>
      <tls_type>tls-auth</tls_type>
      <cert_depth>1</cert_depth>
      <local_network>10.10.1.0/24</local_network>
    </openvpn-server>
  </openvpn>
</pfsense>
